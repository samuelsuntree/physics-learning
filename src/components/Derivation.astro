---
interface Props {
  title?: string;
}
const { title = '展开推导' } = Astro.props;
const id = `derivation-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="my-4">
  <button class="derivation-toggle flex items-center gap-2 text-sm font-medium" onclick={`document.getElementById('${id}').classList.toggle('hidden')`}>
    <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    {title}
  </button>
  <div id={id} class="derivation-content hidden mt-2">
    <slot />
  </div>
</div>
