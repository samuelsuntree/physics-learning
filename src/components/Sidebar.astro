---
import { courses, type Course, type Chapter } from '../i18n/courses';

interface Props {
  courseId: string;
  currentChapter?: string;
  currentSection?: string;
  lang?: string;
}

const { courseId, currentChapter, currentSection, lang = 'zh' } = Astro.props;
const course = courses.find(c => c.id === courseId);
const langKey = lang as 'zh' | 'en';
---

<aside id="sidebar" class="fixed left-0 top-0 h-screen w-72 bg-[var(--color-surface-light)] border-r border-[var(--color-border)] overflow-y-auto z-40 transition-transform -translate-x-full lg:translate-x-0">
  <div class="p-4 border-b border-[var(--color-border)]">
    <a href="/" class="block">
      <h2 class="text-lg font-bold text-white">{course?.title[langKey]}</h2>
      <p class="text-xs text-[var(--color-text-muted)] mt-1">
        {langKey === 'zh' ? '四大力学深度学习平台' : 'Advanced Physics Learning'}
      </p>
    </a>
  </div>

  <nav class="p-3">
    {course?.chapters.map((chapter: Chapter) => (
      <div class="mb-3">
        <a
          href={`/${courseId}/${chapter.id}/`}
          class:list={[
            "block px-3 py-2 text-sm font-medium rounded-lg transition-colors",
            currentChapter === chapter.id
              ? "text-white bg-[var(--color-primary)] bg-opacity-20"
              : "text-[var(--color-text)] hover:bg-[var(--color-surface-lighter)]"
          ]}
        >
          {chapter.title[langKey]}
        </a>
        {currentChapter === chapter.id && (
          <div class="ml-2 mt-1 space-y-0.5">
            {chapter.sections.map(section => (
              <a
                href={`/${courseId}/${chapter.id}/#${section.id}`}
                class:list={[
                  "sidebar-link",
                  currentSection === section.id && "active"
                ]}
              >
                {section.title[langKey]}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>

  <div class="p-3 border-t border-[var(--color-border)]">
    <a
      href={`/${courseId}/interactive/`}
      class="block px-3 py-2 text-sm font-medium rounded-lg transition-colors text-[var(--color-interactive)] hover:bg-[var(--color-surface-lighter)] mb-2"
    >
      {langKey === 'zh' ? '交互实验室' : 'Interactive Lab'}
    </a>
    <a href="/" class="sidebar-link text-xs">
      {langKey === 'zh' ? '← 返回首页' : '← Back to Home'}
    </a>
  </div>
</aside>

<!-- Mobile toggle -->
<button
  id="sidebar-toggle"
  class="lg:hidden fixed top-4 left-4 z-50 p-2 bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-lg"
  aria-label="Toggle sidebar"
>
  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('sidebar');
  toggle?.addEventListener('click', () => {
    sidebar?.classList.toggle('-translate-x-full');
  });
</script>
