const freeEnergyDensity = `$$f(T, n) = \\lim_{\\substack{N\\to\\infty,\\, V\\to\\infty \\\\ N/V = n}} \\frac{F(T, V, N)}{N}$$`;
const largeDeviation = `$$P(x) \\asymp e^{-N\\,I(x)}$$`;
const rateFunction = `$$I(x) = \\sup_\\lambda \\bigl[\\lambda x - \\ln\\langle e^{\\lambda X_1}\\rangle\\bigr]$$`;
const legendreSTF = `$$\\frac{1}{T} = \\frac{\\partial S(E,V,N)}{\\partial E}\\bigg|_{V,N} \\quad \\Longleftrightarrow \\quad F(T,V,N) = E - TS = \\inf_E\\!\\bigl[E - T\\,S(E,V,N)\\bigr]$$`;
const legendreFPhi = `$$\\frac{\\mu}{T} = -\\frac{\\partial}{\\partial N}\\left(\\frac{F}{T}\\right)\\bigg|_{T,V} \\quad \\Longleftrightarrow \\quad \\Phi(T,V,\\mu) = F - \\mu N = \\inf_N\\!\\bigl[F(T,V,N) - \\mu N\\bigr]$$`;
const microcanonicalEntropy = `$$S(E) = k_B \\ln \\Omega(E)$$`;
const canonicalZ = `$$Z(\\beta) = \\int \\Omega(E)\\,e^{-\\beta E}\\,dE = \\int \\exp\\!\\bigl[S(E)/k_B - \\beta E\\bigr]\\,dE$$`;
const saddlePoint = `$$\\frac{\\partial S}{\\partial E}\\bigg|_{E^*} = \\frac{1}{T} = k_B\\beta \\quad \\Longrightarrow \\quad E^* = E^*(\\beta)$$`;
const freeEnergyFromSaddle = `$$F(T) = -k_BT\\ln Z \\approx E^* - T\\,S(E^*) \\quad (N\\to\\infty)$$`;
const concavityCondition = `$$\\frac{\\partial^2 S}{\\partial E^2} \\leq 0 \\quad \\Longleftrightarrow \\quad C_V \\geq 0$$`;
const canonicalCvPositive = `$$C_V = \\frac{\\langle(\\Delta E)^2\\rangle}{k_BT^2} \\geq 0$$`;
const jaynesMaxEnt = `$$S[\\rho] = -k_B\\,\\text{Tr}\\,(\\hat{\\rho}\\ln\\hat{\\rho}) \\to \\max$$`;
const jaynesResult = `$$\\hat{\\rho} = \\frac{1}{Z}\\exp\\!\\left(-\\sum_i \\lambda_i \\hat{O}_i\\right)$$`;
const partitionEquivalence = `$$\\frac{1}{N}\\ln Z_\\text{can} = \\frac{1}{N}\\ln Z_\\text{gc} + O\\!\\left(\\frac{\\ln N}{N}\\right)$$`;
const gravitationalNegativeCv = `$$E_{\\text{tot}} = -\\frac{3}{2}Nk_BT \\quad \\Longrightarrow \\quad C_V = -\\frac{3}{2}Nk_B < 0$$`;
