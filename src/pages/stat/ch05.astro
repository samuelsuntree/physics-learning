const xiBosonSingle = `$$\\Xi_k^{\\text{BE}} = \\sum_{n_k=0}^{\\infty} \\left(ze^{-\\beta\\varepsilon_k}\\right)^{n_k} = \\frac{1}{1 - ze^{-\\beta\\varepsilon_k}}$$`;
