const criticalTemp = `$$T_c = \\frac{2\\pi\\hbar^2}{mk_B}\\left(\\frac{n}{\\zeta(3/2)}\\right)^{\\!2/3}$$`;
const condensateFraction = `$$\\frac{N_0}{N} = 1 - \\left(\\frac{T}{T_c}\\right)^{\\!3/2}$$`;
const becPressure = `$$P(T) = \\frac{\\zeta(5/2)}{\\lambda_T^3}\\,k_BT \\qquad (T < T_c)$$`;
const becCv = `$$C_V = \\frac{15}{4}\\frac{\\zeta(5/2)}{\\zeta(3/2)}\\,Nk_B\\left(\\frac{T}{T_c}\\right)^{\\!3/2} \\approx 1.926\\,Nk_B\\left(\\frac{T}{T_c}\\right)^{\\!3/2} \\qquad (T < T_c)$$`;
const becCvAbove = `$$C_V\\big|_{T_c^+} = \\frac{15}{4}\\frac{\\zeta(5/2)}{\\zeta(3/2)}\\,Nk_B \\approx 1.926\\,Nk_B$$`;
const planckDistribution = `$$u(\\nu, T) = \\frac{8\\pi h\\nu^3}{c^3}\\cdot\\frac{1}{e^{h\\nu/k_BT}-1}$$`;
const stefanBoltzmann = `$$u = \\int_0^{\\infty}u(\\nu,T)\\,d\\nu = \\frac{8\\pi^5 k_B^4}{15h^3c^3}\\,T^4 = aT^4$$`;
const stefanBoltzmannFlux = `$$j = \\sigma T^4, \\qquad \\sigma = \\frac{ac}{4} = \\frac{2\\pi^5 k_B^4}{15h^3c^2} \\approx 5.67\\times 10^{-8}\\;\\text{W\\,m}^{-2}\\text{K}^{-4}$$`;
const wienDisplacement = `$$\\lambda_{\\max} T = b, \\qquad b = \\frac{hc}{4.965\\,k_B} \\approx 2.898\\times 10^{-3}\\;\\text{m}\\cdot\\text{K}$$`;
const radiationEntropy = `$$S = \\frac{4}{3}aT^3 V$$`;
const radiationPressure = `$$P = \\frac{u}{3} = \\frac{a}{3}T^4$$`;
const debyeHeatCapacity = `$$C_V = 9Nk_B\\left(\\frac{T}{\\Theta_D}\\right)^{\\!3}\\int_0^{\\Theta_D/T}\\frac{x^4 e^x}{(e^x - 1)^2}\\,dx$$`;
const debyeT3 = `$$C_V \\approx \\frac{12\\pi^4}{5}Nk_B\\left(\\frac{T}{\\Theta_D}\\right)^{\\!3} \\qquad (T \\ll \\Theta_D)$$`;
const debyeHighT = `$$C_V \\to 3Nk_B \\qquad (T \\gg \\Theta_D)$$`;
const debyeTemp = `$$\\Theta_D = \\frac{\\hbar\\omega_D}{k_B} = \\frac{\\hbar v_s}{k_B}\\left(\\frac{6\\pi^2 N}{V}\\right)^{\\!1/3}$$`;
const boseFunction = `$$g_n(z) = \\frac{1}{\\Gamma(n)}\\int_0^{\\infty}\\frac{x^{n-1}}{z^{-1}e^x - 1}\\,dx = \\sum_{l=1}^{\\infty}\\frac{z^l}{l^n}$$`;
const particleNumberBEC = `$$\\frac{N}{V} = \\frac{g_{3/2}(z)}{\\lambda_T^3}$$`;
const nExcited = `$$N_{\\text{ex}} = \\frac{V}{\\lambda_T^3}\\,\\zeta(3/2) = N\\left(\\frac{T}{T_c}\\right)^{\\!3/2} \\qquad (T \\leq T_c)$$`;
const einsteinCv = `$$C_V^{\\text{Ein}} = 3Nk_B\\left(\\frac{\\Theta_E}{T}\\right)^{\\!2}\\frac{e^{\\Theta_E/T}}{(e^{\\Theta_E/T}-1)^2}$$`;
